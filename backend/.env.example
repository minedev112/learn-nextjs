# Copy to .env and adjust as needed.

# SQLAlchemy database URL (note the +psycopg driver).
DATABASE_URL=postgresql+psycopg://blog:blog@localhost:5432/blog

# Comma-separated allowed CORS origins, or "*" for all.
CORS_ORIGINS=*

# Where uploaded media is stored, and the public base URL used to build links
# to it (files are served under /static/uploads).
UPLOAD_DIR=./static/uploads
PUBLIC_BASE_URL=http://localhost:8000

# Auth. JWT_SECRET signs access tokens — set a long random value in production.
# JWT_EXPIRE_MINUTES is how long a login token stays valid (default 24h).
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRE_MINUTES=1440

# The admin account seeded on first boot (only used when no user exists yet).
# CHANGE the password before deploying.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
