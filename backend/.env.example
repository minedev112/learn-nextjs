# Copy to .env and adjust as needed.

# SQLAlchemy database URL (note the +psycopg driver).
DATABASE_URL=postgresql+psycopg://blog:blog@localhost:5432/blog

# Comma-separated allowed CORS origins, or "*" for all.
CORS_ORIGINS=*

# Where uploaded media is stored, and the public base URL used to build links
# to it (files are served under /static/uploads).
UPLOAD_DIR=./static/uploads
PUBLIC_BASE_URL=http://localhost:8000
